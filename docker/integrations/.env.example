# Copy to .env and fill in your API key.
# Default config uses Groq (free tier, proven working with this demo).
# Leave api_key out of config/ondine_config.yaml — litellm auto-detects standard env vars.

GROQ_API_KEY=gsk_...

# Alternatives (change provider/model in config/ondine_config.yaml):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# TOGETHER_API_KEY=tgp_v1_...
